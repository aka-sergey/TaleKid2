POSTGRESQL_HOST=your-host.twc1.net
POSTGRESQL_PORT=5432
POSTGRESQL_USER=gen_user
POSTGRESQL_PASSWORD=your-password
POSTGRESQL_DBNAME=default_db
POSTGRESQL_SSLMODE=verify-full

S3_ENDPOINT_URL=https://s3.twcstorage.ru
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET=your-bucket-id
STORAGE_PUBLIC_URL=https://s3.twcstorage.ru/your-bucket-id

JWT_SECRET=your-jwt-secret-base64

OPENAI_API_KEY=sk-your-key
LEONARDO_API_KEY=your-leonardo-key

REDIS_URL=redis://default:password@host:port

IMAGE_ENGINE=leonardo
IMAGE_MAX_CONCURRENT=10
